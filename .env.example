# GitHub App Config (Required by octofer)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_BASE64=""
GITHUB_WEBHOOK_SECRET=

# Optional octofer server config
OCTOFER_PORT=3000
OCTOFER_HOST=0.0.0.0

# Bot Config
JULES_API_KEY=
JULES_MODE=SPEED
SESSION_TIMEOUT_MINUTES=25
MAX_PATCH_LENGTH=100000
IGNORE_PATTERNS=*.txt,*.lock,*.png,*.jpg,*.svg,*.ico,dist/,node_modules/
SKIP_DRAFT_PRS=true
