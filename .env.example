# The ID of your GitHub App
APP_ID=
# The private key of your GitHub App (base64 or path)
PRIVATE_KEY=
# The secret for your Webhook
WEBHOOK_SECRET=development
# The webhook proxy url (Required for local development, get one at https://smee.io/)
WEBHOOK_PROXY_URL=

# ──── Jules Configuration ────
# Your Jules API Key (get from https://jules.google → Settings)
JULES_API_KEY=

# ──── Optional ────
# Comma-separated glob patterns of files to ignore
# IGNORE_PATTERNS=docs/,*.md,*.txt,*.lock,dist/
# Max patch length (characters) before skipping a file
# MAX_PATCH_LENGTH=10000
